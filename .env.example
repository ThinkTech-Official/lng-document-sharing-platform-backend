# ── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=https://www.lngccontractor.ca
FRONTEND_URL=https://www.lngccontractor.ca

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars

# ── Azure Blob Storage ────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_CONTAINER_DOCUMENTS=documents
AZURE_CONTAINER_VIDEOS=videos
AZURE_CONTAINER_THUMBNAILS=thumbnails
AZURE_CONTAINER_LOGS_ARCHIVE=logs-archive

# ── Mail ─────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_smtp_username
MAIL_PASS=your_smtp_password
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=LNG Canada Platform

# ── Seed ─────────────────────────────────────────────────────
SUPERADMIN_EMAIL=superadmin@yourdomain.com
SUPERADMIN_NAME=Superadmin
SUPERADMIN_PASSWORD=ChangeMe@123
